<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:QsoRipper.Gui.ViewModels"
             x:Class="QsoRipper.Gui.Views.StationProfileStepView"
             x:DataType="vm:StationProfileStepViewModel">

  <StackPanel Spacing="10">
    <TextBlock Text="Profile Name (required):" FontWeight="SemiBold" />
    <TextBox Text="{Binding ProfileName, Mode=TwoWay}"
             PlaceholderText="e.g. Home, Portable, Contest" />

    <TextBlock Text="Station Callsign (required):" FontWeight="SemiBold" />
    <TextBox Text="{Binding Callsign, Mode=TwoWay}"
             PlaceholderText="e.g. W1AW" />

    <TextBlock Text="Operator Callsign (required):" FontWeight="SemiBold" />
    <TextBox Text="{Binding OperatorCallsign, Mode=TwoWay}"
             PlaceholderText="e.g. W1AW (or personal call if different)" />

    <TextBlock Text="Grid Square (required):" FontWeight="SemiBold" />
    <TextBox Text="{Binding GridSquare, Mode=TwoWay}"
             PlaceholderText="e.g. FN31pr" />

    <TextBlock Text="Operator Name:" />
    <TextBox Text="{Binding OperatorName, Mode=TwoWay}"
             PlaceholderText="e.g. John Smith" />

    <!-- Additional fields in a collapsible section -->
    <Expander Header="Location &amp; Contest Fields" Padding="0,4">
      <StackPanel Spacing="8">
        <Grid ColumnDefinitions="*,12,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Country:" />
          <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding Country, Mode=TwoWay}"
                   PlaceholderText="e.g. United States" />

          <TextBlock Grid.Row="0" Grid.Column="2" Text="State:" />
          <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding State, Mode=TwoWay}"
                   PlaceholderText="e.g. CT" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="County:" Margin="0,6,0,0" />
          <TextBox Grid.Row="3" Grid.Column="0" Text="{Binding County, Mode=TwoWay}"
                   PlaceholderText="e.g. Hartford" />

          <TextBlock Grid.Row="2" Grid.Column="2" Text="ARRL Section:" Margin="0,6,0,0" />
          <TextBox Grid.Row="3" Grid.Column="2" Text="{Binding ArrlSection, Mode=TwoWay}"
                   PlaceholderText="e.g. CT" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="CQ Zone:" Margin="0,6,0,0" />
          <TextBox Grid.Row="5" Grid.Column="0" Text="{Binding CqZone, Mode=TwoWay}"
                   PlaceholderText="e.g. 5" />

          <TextBlock Grid.Row="4" Grid.Column="2" Text="ITU Zone:" Margin="0,6,0,0" />
          <TextBox Grid.Row="5" Grid.Column="2" Text="{Binding ItuZone, Mode=TwoWay}"
                   PlaceholderText="e.g. 8" />

          <TextBlock Grid.Row="6" Grid.Column="0" Text="DXCC:" Margin="0,6,0,0" />
          <TextBox Grid.Row="7" Grid.Column="0" Text="{Binding Dxcc, Mode=TwoWay}"
                   PlaceholderText="e.g. 291" />

          <TextBlock Grid.Row="6" Grid.Column="2" Text="Lat / Lon:" Margin="0,6,0,0" />
          <StackPanel Grid.Row="7" Grid.Column="2" Orientation="Horizontal" Spacing="4">
            <TextBox Text="{Binding Latitude, Mode=TwoWay}" PlaceholderText="Lat" Width="80" />
            <TextBox Text="{Binding Longitude, Mode=TwoWay}" PlaceholderText="Lon" Width="80" />
          </StackPanel>
        </Grid>
      </StackPanel>
    </Expander>
  </StackPanel>
</UserControl>
